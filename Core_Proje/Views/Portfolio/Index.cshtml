@using EntityLayer
@model List<Portfolio>

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    var currentCategory = Context.Request.Query["category"].ToString();
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.css" />

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap');

    .portfolio-main {
        max-width: 1400px;
        margin: 0 auto;
        padding: 3.5rem 6%;
    }

    /* ── Geri butonu ── */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'DM Mono', monospace;
        font-size: 0.68rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        text-decoration: none;
        margin-bottom: 2.5rem;
        transition: color 0.2s ease;
    }
    .back-link:hover { color: var(--accent); text-decoration: none; }
    .back-link svg { transition: transform 0.2s ease; }
    .back-link:hover svg { transform: translateX(-3px); }

    /* ── Sayfa başlığı ── */
    .portfolio-page-header { margin-bottom: 3rem; }
    .portfolio-page-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: 'DM Mono', monospace;
        font-size: 0.7rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--accent);
        margin-bottom: 0.75rem;
    }
    .portfolio-page-eyebrow::before {
        content: '';
        display: inline-block;
        width: 24px; height: 1px;
        background: var(--accent);
    }
    .portfolio-page-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 4vw, 3.2rem);
        font-weight: 600;
        color: var(--text);
        margin: 0;
        line-height: 1.1;
    }
    .portfolio-page-title em { font-style: italic; color: var(--accent); }

    /* ── Web / Yazılım / Mobil kartları ── */
    .web-list { display: flex; flex-direction: column; gap: 4rem; }

    .web-project-card {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.5rem;
        opacity: 0;
        animation: fadeUp 0.6s ease forwards;
    }
    .web-project-card:nth-child(1) { animation-delay: 0.05s; }
    .web-project-card:nth-child(2) { animation-delay: 0.15s; }
    .web-project-card:nth-child(3) { animation-delay: 0.25s; }
    .web-project-card:nth-child(4) { animation-delay: 0.35s; }
    .web-project-card:nth-child(n+5) { animation-delay: 0.4s; }

    .web-img-container {
        width: 100%;
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: var(--surface);
        position: relative;
    }
    .web-img-container img {
        width: 100%; height: auto;
        display: block;
        transition: transform 0.6s ease, filter 0.6s ease;
        filter: brightness(0.9) saturate(0.95);
    }
    .web-project-card:hover .web-img-container img {
        transform: scale(1.02);
        filter: brightness(1) saturate(1);
    }
    /* Subtle overlay */
    .web-img-container::after {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(10,10,10,0.3) 0%, transparent 50%);
        pointer-events: none;
    }

    .web-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1.5rem;
        padding: 0 0.25rem;
    }
    .web-meta { flex: 1; min-width: 0; }
    .web-number {
        font-family: 'DM Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.14em;
        color: var(--accent);
        margin-bottom: 0.35rem;
        text-transform: uppercase;
    }
    .web-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(1.3rem, 2.5vw, 1.9rem);
        font-weight: 600;
        color: var(--text);
        margin: 0;
        line-height: 1.2;
    }

    .btn-visit {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--btn-bg);
        color: var(--btn-text) !important;
        padding: 0.65rem 1.8rem;
        border-radius: 40px;
        text-decoration: none !important;
        font-family: 'DM Sans', sans-serif;
        font-size: 0.83rem;
        font-weight: 500;
        white-space: nowrap;
        flex-shrink: 0;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .btn-visit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(201,169,110,0.25);
    }
    .btn-visit svg { transition: transform 0.2s ease; }
    .btn-visit:hover svg { transform: translateX(3px); }

    /* ── Grafik grid ── */
    .graphic-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }
    .graphic-card {
        position: relative;
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        aspect-ratio: 1 / 1;
        border: 1px solid var(--border);
        opacity: 0;
        animation: fadeUp 0.5s ease forwards;
    }
    .graphic-card:nth-child(n) { animation-delay: calc(0.04s * var(--i, 1)); }
    .graphic-card img {
        width: 100%; height: 100%;
        object-fit: cover;
        transition: transform 0.4s ease, filter 0.4s ease;
        filter: brightness(0.88) saturate(0.9);
    }
    .graphic-card:hover img { transform: scale(1.08); filter: brightness(1) saturate(1); }
    .graphic-card::after {
        content: '';
        position: absolute; inset: 0;
        background: rgba(0,0,0,0);
        transition: background 0.3s ease;
        pointer-events: none;
    }
    .graphic-card:hover::after { background: rgba(0,0,0,0.15); }

    /* Zoom ikon overlay */
    .graphic-zoom {
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%) scale(0.6);
        opacity: 0;
        width: 36px; height: 36px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(6px);
        border: 1px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        color: #fff;
        transition: opacity 0.3s ease, transform 0.3s ease;
        z-index: 1;
        pointer-events: none;
    }
    .graphic-card:hover .graphic-zoom { opacity: 1; transform: translate(-50%, -50%) scale(1); }

    /* ── Boş durum ── */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        border: 1px solid var(--border);
        border-radius: 20px;
        background: var(--surface);
    }
    .empty-state p {
        font-family: 'DM Sans', sans-serif;
        font-size: 0.95rem;
        color: var(--muted);
        margin-bottom: 1.5rem;
    }

    /* ── Separator ── */
    .web-separator {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border), transparent);
        margin-top: 4rem;
    }
    .web-project-card:last-child .web-separator { display: none; }

    /* ── Animasyon ── */
    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 1100px) { .graphic-grid { grid-template-columns: repeat(3, 1fr); } }
    @@media (max-width: 768px) {
        .graphic-grid { grid-template-columns: repeat(2, 1fr); }
        .web-content  { flex-direction: column; align-items: flex-start; gap: 1rem; }
        .web-list     { gap: 3rem; }
    }
    @@media (max-width: 480px) {
        .graphic-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<div class="portfolio-main">

    <!-- Geri butonu -->
    <a href="/#portfolio" class="back-link">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="19" y1="12" x2="5" y2="12"/>
            <polyline points="12 19 5 12 12 5"/>
        </svg>
        Projelere Dön
    </a>

    <!-- Başlık -->
    <div class="portfolio-page-header">
        <span class="portfolio-page-eyebrow">Çalışmalar</span>
        <h1 class="portfolio-page-title">@currentCategory <em>Projeleri</em></h1>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        @if (currentCategory.Contains("Grafik"))
        {
            <!-- Grafik grid -->
            <div class="graphic-grid">
                @foreach (var item in Model)
                {
                    <a href="@item.ImageUrl" class="graphic-card"
                       data-fancybox="gallery" data-caption="@item.Title">
                        <img src="@item.ImageUrl" alt="@item.Title" loading="lazy" />
                        <span class="graphic-zoom">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.5"
                                 stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"/>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                            </svg>
                        </span>
                    </a>
                }
            </div>
        }
        else
        {
            <!-- Web / Yazılım / Mobil listesi -->
            <div class="web-list">
                @{int idx = 1;}
                @foreach (var item in Model)
                {
                    <div class="web-project-card">
                        <div class="web-img-container">
                            <img src="@item.ImageUrl" alt="@item.Title"
                                 onerror="this.src='https://placehold.co/1200x600/111111/c9a96e?text=Görsel+Yüklenemedi'" />
                        </div>
                        <div class="web-content">
                            <div class="web-meta">
                                <p class="web-number">@idx.ToString("D2") / @Model.Count.ToString("D2")</p>
                                <h3 class="web-title">@item.Title</h3>
                            </div>
                            @if (!string.IsNullOrEmpty(item.ProjectUrl))
                            {
                                <a href="@item.ProjectUrl" target="_blank" class="btn-visit">
                                    Siteye Git
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                                         stroke="currentColor" stroke-width="2.5"
                                         stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="5" y1="12" x2="19" y2="12"/>
                                        <polyline points="12 5 19 12 12 19"/>
                                    </svg>
                                </a>
                            }
                        </div>
                        <div class="web-separator"></div>
                    </div>
                    idx++;
                }
            </div>
        }
    }
    else
    {
        <div class="empty-state">
            <p>Bu kategoride henüz bir çalışma eklenmemiş.</p>
            <a href="/#portfolio" class="btn-visit" style="display:inline-flex;">
                Projelere Geri Dön
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2.5"
                     stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
            </a>
        </div>
    }

</div>

<script src="https://cdn.jsdelivr.net/npm/@@fancyapps/ui@5.0/dist/fancybox/fancybox.umd.js"></script>
<script>
    Fancybox.bind("[data-fancybox='gallery']", {
        dragToClose: false,
        Toolbar: { display: { left: ["infobar"], right: ["slideshow", "thumbs", "close"] } }
    });
</script>