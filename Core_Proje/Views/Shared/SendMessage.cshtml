@model EntityLayer.Message

<style>
    .contact-form-container {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 2rem;
    }

    .form-group-custom {
        position: relative;
        margin-bottom: 1rem;
    }

    .form-control-custom {
        width: 100%;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 0.85rem 1.1rem;
        color: var(--text);
        font-family: 'DM Sans', sans-serif;
        font-size: 0.88rem;
        transition: border-color 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
        outline: none;
        resize: none;
        display: block;
    }
    .form-control-custom::placeholder {
        color: var(--muted);
        opacity: 0.7;
    }
    .form-control-custom:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-dim);
        background: var(--surface);
    }
    body.light-mode .form-control-custom {
        background: #ffffff;
    }
    body.light-mode .form-control-custom:focus {
        background: #ffffff;
    }

    /* Label animasyonu */
    .form-label-custom {
        display: block;
        font-family: 'DM Mono', monospace;
        font-size: 0.62rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 0.4rem;
        transition: color 0.25s ease;
    }
    .form-group-custom:focus-within .form-label-custom {
        color: var(--accent);
    }

    .form-row-custom {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
        margin-bottom: 1rem;
    }
    @@media (max-width: 576px) {
        .form-row-custom { grid-template-columns: 1fr; }
    }

    .btn-submit {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--btn-bg);
        color: var(--btn-text) !important;
        border: none;
        padding: 0.7rem 2rem;
        border-radius: 40px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 500;
        font-size: 0.85rem;
        cursor: pointer;
        transition: transform 0.2s ease, box-shadow 0.2s ease, opacity 0.2s;
        margin-top: 0.5rem;
    }
    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(201,169,110,0.25);
        opacity: 0.9;
    }
    .btn-submit svg { transition: transform 0.2s ease; }
    .btn-submit:hover svg { transform: translateX(3px); }
</style>

<div class="contact-form-container">
    <form action="/Default/SendMessage" method="post">

        <div class="form-row-custom">
            <div class="form-group-custom">
                <label class="form-label-custom">İsim</label>
                <input type="text" name="SenderName" class="form-control-custom" placeholder="Yavuz Beydoğan" required />
            </div>
            <div class="form-group-custom">
                <label class="form-label-custom">Email</label>
                <input type="email" name="SenderEmail" class="form-control-custom" placeholder="ornek@email.com" required />
            </div>
        </div>

        <div class="form-group-custom" style="margin-bottom:1rem;">
            <label class="form-label-custom">Başlık</label>
            <input type="text" name="Subject" class="form-control-custom" placeholder="Konu başlığı" required />
        </div>

        <div class="form-group-custom" style="margin-bottom:1.2rem;">
            <label class="form-label-custom">Mesaj</label>
            <textarea name="Content" class="form-control-custom" rows="5" placeholder="Mesajınızı buraya yazın..." required></textarea>
        </div>

        <button type="submit" class="btn-submit">
            Gönder
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                 stroke="currentColor" stroke-width="2.5"
                 stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="12 5 19 12 12 19"/>
            </svg>
        </button>

    </form>
</div>