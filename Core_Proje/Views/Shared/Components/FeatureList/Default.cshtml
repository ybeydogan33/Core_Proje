@using EntityLayer
@model List<Feature>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&display=swap');

    .hero-section {
        position: relative; z-index: 1;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 4rem;
        padding: 0 6%;
        height: calc(100vh - 68px);
        max-height: 860px;
        max-width: 1600px;
        margin: 0 auto;
        overflow: hidden;
    }
    .hero-section::before {
        content: ''; position: absolute; top: 0; left: 6%; right: 6%;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--border), transparent);
    }

    /* ── Sol içerik ── */
    .hero-content { max-width: 520px; }

    .hero-tag {
        display: inline-flex; align-items: center; gap: 0.5rem;
        font-family: 'DM Mono', monospace; font-size: 0.7rem;
        letter-spacing: 0.18em; text-transform: uppercase;
        color: var(--accent); margin-bottom: 1rem;
        opacity: 0; animation: fadeUp 0.7s 0.1s ease forwards;
    }
    .hero-tag::before { content: ''; display: inline-block; width: 24px; height: 1px; background: var(--accent); }

    .hero-name {
        font-family: 'DM Mono', monospace; font-size: 0.75rem;
        letter-spacing: 0.12em; color: var(--muted); text-transform: uppercase;
        margin-bottom: 0.5rem;
        opacity: 0; animation: fadeUp 0.7s 0.2s ease forwards;
    }

    .hero-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2.2rem, 3.5vw, 3.6rem);
        font-weight: 600; line-height: 1.1; color: var(--text);
        margin: 0 0 1.1rem;
        opacity: 0; animation: fadeUp 0.7s 0.3s ease forwards;
    }
    .hero-title em { font-style: italic; color: var(--accent); }

    .hero-description {
        font-family: 'DM Sans', sans-serif; font-size: 0.92rem;
        line-height: 1.75; color: var(--muted);
        margin-bottom: 1.8rem; max-width: 400px;
        opacity: 0; animation: fadeUp 0.7s 0.4s ease forwards;
    }

    .hero-cta {
        display: flex; align-items: center; gap: 1rem; flex-wrap: wrap;
        margin-bottom: 2rem;
        opacity: 0; animation: fadeUp 0.7s 0.5s ease forwards;
    }

    .hero-btn {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.65rem 1.8rem;
        background-color: var(--btn-bg); color: var(--btn-text) !important;
        text-decoration: none !important; border-radius: 40px;
        font-family: 'DM Sans', sans-serif; font-size: 0.83rem;
        font-weight: 500;
        transition: transform 0.25s ease, box-shadow 0.25s ease;
    }
    .hero-btn:hover { transform: translateY(-2px); box-shadow: 0 8px 28px rgba(201,169,110,0.25); }
    .hero-btn svg { transition: transform 0.25s ease; }
    .hero-btn:hover svg { transform: translateX(3px); }

    /* ── Sosyal linkler — etiketli pill ── */
    .hero-socials {
        display: flex; flex-wrap: wrap; gap: 0.6rem;
        opacity: 0; animation: fadeUp 0.7s 0.6s ease forwards;
    }
    .hero-social-link {
        display: inline-flex; align-items: center; gap: 0.5rem;
        padding: 0.42rem 1rem;
        border: 1px solid var(--border);
        border-radius: 40px;
        background: transparent;
        color: var(--muted) !important;
        text-decoration: none !important;
        font-family: 'DM Mono', monospace;
        font-size: 0.65rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        transition: border-color 0.25s, color 0.25s, background 0.25s, transform 0.25s;
    }
    .hero-social-link i { font-size: 0.85rem; }
    .hero-social-link:hover {
        border-color: var(--accent);
        color: var(--accent) !important;
        background: var(--accent-dim);
        transform: translateY(-2px);
    }

    /* ── Sağ taraf ── */
    .hero-right {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.5rem;
        height: 100%;
        opacity: 0; animation: fadeIn 1s 0.5s ease forwards;
    }

    /* Fotoğraf — kare köşeli, editorial */
    .hero-visual {
        position: relative;
        width: 100%;
        max-width: 360px;
        flex-shrink: 0;
    }
    .hero-image-container {
        width: 100%;
        aspect-ratio: 4 / 5;
        border-radius: 24px;
        overflow: hidden;
        background: var(--surface);
        border: 1px solid var(--border);
        box-shadow: 0 30px 60px rgba(0,0,0,0.4);
        position: relative;
    }
    .hero-image-container img {
        width: 100%; height: 100%; object-fit: cover;
        transition: transform 0.6s ease;
    }
    .hero-visual:hover .hero-image-container img { transform: scale(1.04); }

    /* Köşe dekor */
    .hero-image-container::after {
        content: '';
        position: absolute; inset: 0;
        background: linear-gradient(to top, rgba(10,10,10,0.35) 0%, transparent 50%);
        pointer-events: none;
    }

   
    /* ── Animasyonlar ── */
    @@keyframes fadeUp  { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes fadeIn  { from{opacity:0;transform:scale(0.97)}      to{opacity:1;transform:scale(1)} }
    @@keyframes floatY  { 0%,100%{transform:translateY(0)} 50%{transform:translateY(-6px)} }

    /* ── Responsive ── */
    @@media (max-width: 960px) {
        .hero-section {
            grid-template-columns: 1fr;
            text-align: center;
            height: auto; max-height: none;
            padding: 4rem 6% 3rem;
            gap: 2.5rem;
        }
        .hero-content { max-width: 100%; }
        .hero-description { max-width: 100%; margin: 0 auto 1.8rem; }
        .hero-cta     { justify-content: center; }
        .hero-socials { justify-content: center; }
        .hero-tag     { justify-content: center; }
        .hero-right   { height: auto; }
        .hero-visual  { max-width: 280px; margin: 0 auto; }
        .hero-exp-badge { right: -8px; }
    }
    @@media (max-width: 480px) {
        .hero-title { font-size: 2rem; }
        .hero-visual { max-width: 240px; }
    }
</style>

@if (Model != null && Model.Count > 0)
{
    @foreach (var item in Model)
    {
        <section class="hero-section">

            <!-- Sol içerik -->
            <div class="hero-content">
                <span class="hero-tag">Backend Developer</span>
                <p class="hero-name">@item.Name</p>

                <h1 class="hero-title">
                    @{
                        var words = item.Title?.Split(' ') ?? Array.Empty<string>();
                        var half  = words.Length / 2;
                    }
                    @string.Join(" ", words.Take(half))
                    @if (half < words.Length)
                    {
                        <em> @string.Join(" ", words.Skip(half))</em>
                    }
                </h1>

                <p class="hero-description">@item.Description</p>

                <div class="hero-cta">
                    <a href="@item.CvUrl" target="_blank" class="hero-btn">
                        Özgeçmiş
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"/>
                            <polyline points="12 5 19 12 12 19"/>
                        </svg>
                    </a>
                </div>

                <div class="hero-socials">
                    <a href="https://github.com/ybeydogan33" target="_blank"
                       class="hero-social-link" aria-label="GitHub">
                        <i class="fab fa-github"></i> GitHub
                    </a>
                    <a href="https://linkedin.com/in/yavuzbeydogan/" target="_blank"
                       class="hero-social-link" aria-label="LinkedIn">
                        <i class="fab fa-linkedin-in"></i> LinkedIn
                    </a>
                    <a href="https://instagram.com/yavuzbeydogan" target="_blank"
                       class="hero-social-link" aria-label="Instagram">
                        <i class="fab fa-instagram"></i> Instagram
                    </a>
                    <a href="https://bionluk.com/yavuzalp_" target="_blank"
                       class="hero-social-link" aria-label="Bionluk">
                        <i class="fas fa-briefcase"></i> Bionluk
                    </a>
                </div>
            </div>

            <!-- Sağ görsel -->
            <div class="hero-right">
                <div class="hero-visual">
                    <div class="hero-image-container">
                        <img src="@item.ImageUrl" alt="@item.Name"
                             onerror="this.src='https://placehold.co/360x450/111111/c9a96e?text=YA'" />
                    </div>
                </div>
            </div>

        </section>
    }
}