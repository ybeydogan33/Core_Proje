@using EntityLayer
@model List<Experience>

<style>
    .resume-card {
        display: flex; align-items: flex-start; gap: 1rem;
        padding: 1.1rem 1.2rem;
        background: var(--surface); border: 1px solid var(--border);
        border-radius: 16px; position: relative;
        transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
        overflow: hidden;
    }
    .resume-card::before {
        content: ''; position: absolute; left: 0; top: 0; bottom: 0;
        width: 3px;
        background: linear-gradient(to bottom, var(--accent), transparent);
        opacity: 0; transition: opacity 0.3s ease;
    }
    .resume-card:hover { transform: translateY(-3px); box-shadow: 0 12px 36px rgba(0,0,0,0.25); border-color: var(--accent-dim); }
    .resume-card:hover::before { opacity: 1; }

    .resume-logo-wrap {
        width: 44px; height: 44px; border-radius: 10px;
        overflow: hidden; flex-shrink: 0; background: #fff;
        border: 1px solid var(--border);
        display: flex; align-items: center; justify-content: center;
    }
    .resume-logo { width: 100%; height: 100%; object-fit: cover; }

    .resume-content { flex: 1; min-width: 0; }
    .resume-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 0.5rem; margin-bottom: 0.2rem; }
    .resume-title {
        font-family: 'DM Sans', sans-serif; font-size: 0.92rem; font-weight: 500;
        color: var(--text); margin: 0;
        white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .resume-date {
        font-family: 'DM Mono', monospace; font-size: 0.62rem;
        letter-spacing: 0.08em; color: var(--accent); white-space: nowrap; margin: 0; padding-top: 2px;
    }
    .resume-company {
        font-family: 'DM Sans', sans-serif; font-size: 0.78rem; color: var(--muted); margin: 0;
    }
</style>

@foreach (var item in Model)
{
    <div class="resume-card">
        <div class="resume-logo-wrap">
            <img src="@item.LogoUrl" alt="@item.Company" class="resume-logo"
                 onerror="this.style.display='none'" />
        </div>
        <div class="resume-content">
            <div class="resume-top">
                <h5 class="resume-title">@item.Title</h5>
                <p class="resume-date">@item.DateRange</p>
            </div>
            <p class="resume-company">@item.Company</p>
        </div>
    </div>
}