@* Modernized Navbar Partial *@
<style>
    @@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400&family=Playfair+Display:wght@600&display=swap');

    :root {
        --bg:         #0a0a0a;
        --surface:    #111111;
        --border:     rgba(255,255,255,0.07);
        --text:       #f0ede6;
        --muted:      #6b6b6b;
        --accent:     #c9a96e;
        --accent-dim: rgba(201,169,110,0.12);
        --btn-bg:     #c9a96e;
        --btn-text:   #0a0a0a;
    }
    body.light-mode {
        --bg:         #f7f5f0;
        --surface:    #eeebe3;
        --border:     rgba(0,0,0,0.08);
        --text:       #1a1a1a;
        --muted:      #888888;
        --accent:     #9b6f2f;
        --accent-dim: rgba(155,111,47,0.10);
        --btn-bg:     #1a1a1a;
        --btn-text:   #f7f5f0;
    }
    body { background-color: var(--bg); color: var(--text); transition: background-color 0.3s, color 0.3s; }

    #header-nav {
        background: transparent;
        backdrop-filter: blur(18px); -webkit-backdrop-filter: blur(18px);
        border-bottom: 1px solid var(--border);
        padding: 0; transition: background 0.3s ease;
    }
    #header-nav.scrolled { background: rgba(10,10,10,0.82); }
    body.light-mode #header-nav.scrolled { background: rgba(247,245,240,0.90); }
    #header-nav .container { height: 68px; display: flex; align-items: center; }

    .navbar-brand {
        font-family: 'Playfair Display', serif !important;
        font-size: 1.15rem !important; font-weight: 600 !important;
        color: var(--text) !important; text-decoration: none !important;
        transition: opacity 0.2s;
    }
    .navbar-brand span { color: var(--accent); }
    .navbar-brand:hover { opacity: 0.75; }

    .nav-link {
        font-family: 'DM Mono', monospace !important;
        font-size: 0.7rem !important; letter-spacing: 0.1em !important;
        text-transform: uppercase !important; color: var(--muted) !important;
        padding: 0.3rem 0 !important; position: relative;
        transition: color 0.2s ease !important;
    }
    .nav-link::after {
        content: ''; position: absolute; bottom: -2px; left: 0;
        width: 0; height: 1px; background: var(--accent); transition: width 0.3s ease;
    }
    .nav-link:hover { color: var(--text) !important; }
    .nav-link:hover::after { width: 100%; }
    .nav-link.active-link { color: var(--accent) !important; }
    .nav-link.active-link::after { width: 100%; }

    #themeToggle {
        background: transparent !important;
        border: 1px solid var(--border) !important;
        border-radius: 40px !important; padding: 0.38rem 0.9rem !important;
        font-family: 'DM Mono', monospace !important;
        font-size: 0.65rem !important; letter-spacing: 0.08em !important;
        text-transform: uppercase !important;
        display: flex !important; align-items: center !important; gap: 0.4rem !important;
        color: var(--muted) !important;
        transition: border-color 0.25s, color 0.25s, background 0.25s !important;
        cursor: pointer; white-space: nowrap; line-height: 1;
    }
    #themeToggle:hover {
        border-color: var(--accent) !important;
        color: var(--accent) !important;
        background: var(--accent-dim) !important;
    }
    .theme-icon { font-size: 0.75rem; transition: transform 0.4s ease; }
    #themeToggle:hover .theme-icon { transform: rotate(20deg); }

    .nav-cv-btn {
        font-family: 'DM Sans', sans-serif !important;
        font-size: 0.8rem !important; font-weight: 500 !important;
        color: var(--btn-text) !important; background: var(--btn-bg) !important;
        border: none !important; border-radius: 40px !important;
        padding: 0.45rem 1.3rem !important; text-decoration: none !important;
        display: inline-flex; align-items: center; gap: 0.4rem;
        transition: transform 0.2s ease, box-shadow 0.2s ease !important;
    }
    .nav-cv-btn:hover {
        transform: translateY(-1px) !important;
        box-shadow: 0 6px 22px rgba(201,169,110,0.28) !important;
    }
    .nav-cv-btn svg { transition: transform 0.2s; }
    .nav-cv-btn:hover svg { transform: translateX(3px); }

    .navbar-toggler { border: none !important; padding: 0.25rem !important; box-shadow: none !important; }
    .navbar-toggler:focus { box-shadow: none !important; }
    .hamburger-icon { display: flex; flex-direction: column; gap: 5px; width: 22px; }
    .hamburger-icon span {
        display: block; height: 1.5px; background: var(--text);
        border-radius: 2px;
        transition: transform 0.3s ease, opacity 0.3s ease, width 0.3s ease;
    }
    .hamburger-icon span:last-child { width: 14px; }
    .navbar-toggler[aria-expanded="true"] .hamburger-icon span:first-child { transform: translateY(6.5px) rotate(45deg); }
    .navbar-toggler[aria-expanded="true"] .hamburger-icon span:nth-child(2) { opacity: 0; transform: scaleX(0); }
    .navbar-toggler[aria-expanded="true"] .hamburger-icon span:last-child { transform: translateY(-6.5px) rotate(-45deg); width: 22px; }

    @@media (max-width: 991px) {
        #navbarSupportedContent {
            background: var(--surface); border: 1px solid var(--border);
            border-radius: 16px; padding: 1.2rem 1.4rem; margin-top: 0.5rem;
        }
        .navbar-nav { gap: 0.1rem !important; }
        .nav-link { padding: 0.5rem 0 !important; }
        .nav-link::after { display: none; }
        .nav-item.ms-lg-2 { margin-left: 0 !important; margin-top: 0.8rem; }
    }
</style>

<header class="sticky-top" style="z-index: 1030;">
    <nav class="navbar navbar-expand-lg" id="header-nav" role="navigation">
        <div class="container">
            <a class="navbar-brand" href="/#home">Yavuz&#160;<span>Beydoğan</span></a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navbarSupportedContent"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <div class="hamburger-icon"><span></span><span></span><span></span></div>
            </button>
            <div class="collapse navbar-collapse" id="navbarSupportedContent">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center gap-3">
                    <li class="nav-item"><a class="nav-link" href="/#home">Ana Sayfa</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#portfolio">Projeler</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#about">Hakkımda</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#certificates">Sertifikalar</a></li>
                    <li class="nav-item"><a class="nav-link" href="/#contact">İletişim</a></li>
                    <li class="nav-item ms-lg-2">
                        <button id="themeToggle" class="btn btn-sm" type="button">
                            <i id="themeIcon" class="fas theme-icon"></i>
                            <span id="themeLabel"></span>
                        </button>
                    </li>
                    <li class="nav-item">
                        <a class="nav-cv-btn" href="/pdf/YavuzCV.pdf" target="_blank">
                            Özgeçmiş
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none"
                                 stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                            </svg>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<script>
(function () {
    var nav = document.getElementById('header-nav');
    window.addEventListener('scroll', function () {
        nav.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });

    var navLinks = document.querySelectorAll('.nav-link');
    var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
            if (e.isIntersecting) {
                navLinks.forEach(function (l) { l.classList.remove('active-link'); });
                var active = document.querySelector('.nav-link[href="/#' + e.target.id + '"]');
                if (active) active.classList.add('active-link');
            }
        });
    }, { rootMargin: '-40% 0px -55% 0px', threshold: 0 });
    document.querySelectorAll('section[id]').forEach(function (s) { io.observe(s); });

    var toggle = document.getElementById('themeToggle');
    var icon   = document.getElementById('themeIcon');
    var label  = document.getElementById('themeLabel');

    function setTheme(isDark) {
        document.body.classList.toggle('light-mode', !isDark);
        icon.className    = isDark ? 'fas fa-moon theme-icon' : 'fas fa-sun theme-icon';
        label.textContent = isDark ? 'Koyu Mod' : 'Açık Mod';
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
    }

    setTheme(localStorage.getItem('theme') !== 'light');

    toggle.addEventListener('click', function () {
        setTheme(document.body.classList.contains('light-mode'));
    });
}());
</script>