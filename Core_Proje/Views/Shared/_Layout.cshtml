<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Yavuz Beydoğan</title>
    <link rel="icon" type="image/png" href="~/Image/panda.png" />
    <link rel="apple-touch-icon" href="~/Image/panda.png" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
          integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />

    <style>
        html { scroll-behavior: smooth; }

        body {
            font-family: 'DM Sans', 'Segoe UI', sans-serif;
            margin: 0;
            padding: 0;
        }

        /* Navbar tıklamalarında başlık menünün altında kalmasın */
        #home, #portfolio, #about, #certificates, #contact {
            scroll-margin-top: 80px;
        }

        /* Footer */
        .custom-footer {
            padding: 2rem 0;
            margin-top: 3rem;
            font-size: 0.82rem;
            color: var(--muted);
            border-top: 1px solid var(--border);
            text-align: center;
            font-family: 'DM Mono', monospace;
            letter-spacing: 0.06em;
            transition: border-color 0.3s ease, color 0.3s ease;
        }
    </style>
</head>
<body>

    @await Html.PartialAsync("NavbarPartial")

    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer class="custom-footer">
        <div class="container">
            <p class="mb-0">&copy; 2026 Yavuz Beydoğan. Tüm hakları saklıdır.</p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>